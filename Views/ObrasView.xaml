<UserControl x:Class="armonte_aplicacao.Views.ObrasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:armonte_aplicacao.ViewModels">
    <UserControl.DataContext>
        <vm:ObrasViewModel />
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de pesquisa + adicionar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox Text="{Binding TextoPesquisa, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" Margin="0,0,8,0"
                     ToolTip="Pesquisar por nome, morada..."/>

            <Button Content="Pesquisar" Command="{Binding PesquisarCommand}" Padding="10,3" Margin="0,0,20,0"/>

            <Button Content="Adicionar Obra" Command="{Binding AbrirFormularioAdicionarCommand}" Padding="10,3"/>
        </StackPanel>

        <!-- Tabela de obras -->
        <DataGrid ItemsSource="{Binding ListaObras}" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="150"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="80"/>
                <DataGridTextColumn Header="Morada" Binding="{Binding Morada}" Width="150"/>
                <DataGridTextColumn Header="Morada Contabilística" Binding="{Binding MoradaContabilistica}" Width="150"/>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remover"
                                    Command="{Binding DataContext.RemoverObraCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>